{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd apps/dashboard && npx tsc --noEmit 2>&1 | head -20"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | grep -iE '(DROP TABLE|DROP DATABASE|DELETE FROM [a-z]+ WHERE 1|TRUNCATE)' && echo 'BLOQUEADO: comando destrutivo detectado' && exit 2 || exit 0"
          }
        ]
      }
    ]
  }
}
