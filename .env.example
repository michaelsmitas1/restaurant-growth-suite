# ══════════════════════════════════════
# Restaurante Growth Suite — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════

# ── Anthropic (Claude API) ──────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase ────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Para n8n conectar diretamente no PostgreSQL:
SUPABASE_DB_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_DB_PASSWORD=sua-senha-do-banco

# ── Evolution API (WhatsApp) ─────────────
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=seu-api-key-seguro-aqui
EVOLUTION_PUBLIC_URL=https://evolution.seudominio.com
EVOLUTION_HOST=evolution.seudominio.com

# ── n8n ─────────────────────────────────
N8N_HOST=n8n.seudominio.com
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=chave-aleatoria-minimo-32-caracteres-aqui
N8N_USER=admin
N8N_PASSWORD=senha-segura-aqui
WEBHOOK_URL=https://n8n.seudominio.com

# ── Wallet Service (legado, Apple pkpass) ─
SERVICE_URL=https://wallet.seudominio.com
APPLE_CERT_PASSPHRASE=senha-do-certificado-p12

# ── Google Wallet (spec 008) ─────────────
# JSON completo da service account (Google Cloud → IAM → Service Accounts → chave JSON), em uma linha.
GOOGLE_WALLET_SA_KEY={"client_email":"...","private_key":"..."}
GOOGLE_WALLET_ISSUER_ID=000000000000000000
GOOGLE_WALLET_LOGO_URL=https://seudominio.com/logo.png
# URL pública do dashboard — usada para montar o link /w/[slug] do QR de fidelidade
NEXT_PUBLIC_APP_URL=https://app.seudominio.com

# ── Google OAuth ─────────────────────────
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# ── Dashboard Next.js ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ATENÇÃO: nunca exponha SUPABASE_SERVICE_KEY no frontend
